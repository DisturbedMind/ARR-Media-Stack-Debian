# External LAN Caddy port-mirror example.
#
# Use this only when Caddy runs on a different machine/IP from the ARR stack.
# It lets you browse to:
#
#   http://192.168.137.251:7878  -> Radarr
#   http://192.168.137.251:8989  -> Sonarr
#   http://192.168.137.251:8686  -> Lidarr
#   http://192.168.137.251:6969  -> Whisparr v3
#   http://192.168.137.251:6970  -> Whisparr v2
#   http://192.168.137.251:6789  -> NZBGet
#
# Keep every Arr app URL Base blank.
#
# Replace ARR_STACK_IP with the Debian server IP that runs Docker + NZBGet.
# Do not use this file if Caddy and the ARR stack run on the same IP with
# those same ports already published, because the ports will conflict.

{
	auto_https off
}

http://192.168.137.251:7878 {
	reverse_proxy ARR_STACK_IP:7878
}

http://192.168.137.251:8989 {
	reverse_proxy ARR_STACK_IP:8989
}

http://192.168.137.251:8686 {
	reverse_proxy ARR_STACK_IP:8686
}

http://192.168.137.251:6969 {
	reverse_proxy ARR_STACK_IP:6969
}

http://192.168.137.251:6970 {
	reverse_proxy ARR_STACK_IP:6970
}

http://192.168.137.251:6789 {
	reverse_proxy ARR_STACK_IP:6789
}
